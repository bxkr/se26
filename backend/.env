# =========================
# COMMON
# =========================
LOG_LEVEL=INFO

# =========================
# PostgreSQL
# =========================
POSTGRES_DB=weather_db
POSTGRES_USER=weather_user
POSTGRES_PASSWORD=weather_pass
POSTGRES_PORT=5432
POSTGRES_DSN=postgresql://weather_user:weather_pass@postgres:5432/weather_db

# =========================
# Redis
# =========================
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# =========================
# S3 / MinIO
# =========================
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=raw-data
S3_REGION=us-east-1
S3_PORT=9000
MINIO_CONSOLE_PORT=9001
S3_ENDPOINT_URL=http://minio:9000

# =========================
# Kafka
# =========================
KAFKA_CLUSTER_ID=MkU3OEVBNTcwNTJENDM2Qk
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_EXTERNAL_PORT=29092
KAFKA_UI_PORT=8080
FORECAST_TOPIC=forecast.raw
ACTUAL_TOPIC=actual.raw

# =========================
# ClickHouse
# =========================
CLICKHOUSE_HOST=clickhouse
CLICKHOUSE_PORT=8123
CLICKHOUSE_HTTP_PORT=8123
CLICKHOUSE_NATIVE_PORT=9002
CLICKHOUSE_USER=app
CLICKHOUSE_PASSWORD=app_pass
CLICKHOUSE_DATABASE=default

# =========================
# Service Ports
# =========================
FORECAST_SERVICE_PORT=8001
ACTUAL_SERVICE_PORT=8002
ACCURACY_ETL_SERVICE_PORT=8003
ANALYTICS_API_SERVICE_PORT=8004
ALERT_SERVICE_PORT=8005